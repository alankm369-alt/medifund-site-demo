<!DOCTYPE html>
<html>
<head>
    <title>MedFund App</title>

    <style>
        body {
            font-family: Arial;
            background: linear-gradient(135deg, #dfe9f3, #ffffff);
            text-align: center;
            overflow: hidden;
        }

        .box {
            background: white;
            padding: 20px;
            margin: 80px auto;
            width: 300px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            opacity: 0;
            transform: translateY(30px);
            animation: fadeIn 0.6s ease forwards;
        }

        @keyframes fadeIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            background: linear-gradient(45deg, #00b09b, #00c9a7);
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        .hidden {
            display: none;
        }

        .loader {
            margin: 20px auto;
            border: 5px solid #eee;
            border-top: 5px solid #00b09b;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            100% { transform: rotate(360deg); }
        }
    </style>
</head>

<body>

<!-- LOGIN -->
<div class="box" id="login">
    <h2>Login</h2>
    <input type="text" id="loginUser" placeholder="Username">
    <input type="password" id="loginPass" placeholder="Password">
    <button onclick="login()">Login</button>
    <p>Don't have account?</p>
    <button onclick="switchPage('login','signup')">Signup</button>
</div>

<!-- SIGNUP -->
<div class="box hidden" id="signup">
    <h2>Signup</h2>
    <input type="text" id="newUser" placeholder="Username">
    <input type="password" id="newPass" placeholder="Password">
    <button onclick="signup()">Create Account</button>
    <button onclick="switchPage('signup','login')">Back</button>
</div>

<!-- HOME -->
<div class="box hidden" id="home">
    <h2>💊 MedFund</h2>
    <h3>Wallet Balance</h3>
    <p id="balance">₹0</p>

    <button onclick="goToPayment()">Add Money</button>
    <button onclick="emergency()">Emergency Request</button>
    <button onclick="logout()">Logout</button>
</div>

<!-- PAYMENT -->
<div class="box hidden" id="payment">
    <h3>Enter Amount</h3>
    <input type="number" id="amount" placeholder="Enter amount">
    <button onclick="nextStep()">Next</button>
</div>

<!-- UPI -->
<div class="box hidden" id="upi">
    <h3>Enter UPI ID</h3>
    <input type="text" placeholder="example@upi">
    <button onclick="addMoney()">Proceed</button>
</div>

<!-- LOADING -->
<div class="box hidden" id="loading">
    <h3>Requesting Fund...</h3>
    <div class="loader"></div>
    <p>Please wait</p>
</div>

<script>

let balance = 0;

function switchPage(hide, show) {
    document.getElementById(hide).classList.add("hidden");
    document.getElementById(show).classList.remove("hidden");
}

/* SIGNUP */
function signup() {
    let user = document.getElementById("newUser").value;
    let pass = document.getElementById("newPass").value;

    if(user && pass) {
        localStorage.setItem("username", user);
        localStorage.setItem("password", pass);
        alert("Account created!");
        switchPage("signup","login");
    } else {
        alert("Fill all fields!");
    }
}

/* LOGIN */
function login() {
    let user = document.getElementById("loginUser").value;
    let pass = document.getElementById("loginPass").value;

    let savedUser = localStorage.getItem("username");
    let savedPass = localStorage.getItem("password");

    if(user === savedUser && pass === savedPass) {
        switchPage("login","home");
    } else {
        alert("Invalid login!");
    }
}

/* LOGOUT */
function logout() {
    switchPage("home","login");
}

/* PAYMENT FLOW */
function goToPayment() {
    switchPage("home","payment");
}

function nextStep() {
    let amount = document.getElementById("amount").value;
    if(amount > 0) {
        switchPage("payment","upi");
    } else {
        alert("Enter valid amount!");
    }
}

function addMoney() {
    let amount = parseInt(document.getElementById("amount").value);
    balance += amount;
    document.getElementById("balance").innerText = "₹" + balance;

    alert("Money added!");
    switchPage("upi","home");
}

/* EMERGENCY */
function emergency() {
    switchPage("home","loading");

    setTimeout(() => {
        alert("Request sent!");
        window.open("https://docs.google.com/forms/d/e/1FAIpQLSdF8uvWdWYX8SZtuFWQbD00H-jN-Os7wSm3xnriti_bUzVN5Q/viewform", "_blank");
        switchPage("loading","home");
    }, 3000);
}

</script>

</body>
</html>
